#!name = Apple TV 内容语言切换
#!desc = 强制 Apple TV app 使用指定地区目录：搜索/合集/用户设置直接切换；首页/频道/继续观看/剧集/电影详情页均通过并行请求合并文本(标题/简介/演员/分类)，同时保留真实日区身份用于播放，避免"无法播放此视频"以及"继续观看"直接点播失败。已知限制：详情页顶部大标题不受影响，仍为原始语言；首页内容因地区间个性化推荐顺序不同，极少数卡片翻译可能对应错位（不影响播放）。iOS / tvOS 通用。
#!category = Custom
#!arguments = region:"hk"
#!arguments-desc = region: 目标地区，可选 hk（繁中·已验证）/ tw（繁中·已验证）/ jp（还原日区/相当于关闭）

[Script]
TV Force Region = type=http-request, pattern=^https?:\/\/uts-api\.itunes\.apple\.com\/uts\/v3\/(search|collections|user\/settings|contents\/[^\/]+\/personalized-flags)(\/|\?|$), requires-body=0, max-size=0, script-path=https://raw.githubusercontent.com/kuroidark/surge/refs/heads/main/script/tv-force-region.js, argument=region="{{{region}}}"
TV Translate Canvases = type=http-response, pattern=^https?:\/\/uts-api\.itunes\.apple\.com\/uts\/v3\/canvases\/, requires-body=1, max-size=5242880, timeout=25, script-path=https://raw.githubusercontent.com/kuroidark/surge/refs/heads/main/script/canvases-translate.js, argument=region="{{{region}}}"
TV Translate Shelves = type=http-response, pattern=^https?:\/\/uts-api\.itunes\.apple\.com\/uts\/v3\/shelves\/, requires-body=1, max-size=5242880, timeout=25, script-path=https://raw.githubusercontent.com/kuroidark/surge/refs/heads/main/script/canvases-translate.js, argument=region="{{{region}}}"
TV Translate Show Detail = type=http-response, pattern=^https?:\/\/uts-api\.itunes\.apple\.com\/uts\/v3\/shows\/[^\/]+(\?|$), requires-body=1, max-size=2097152, timeout=20, script-path=https://raw.githubusercontent.com/kuroidark/surge/refs/heads/main/script/shows-detail-translate.js, argument=region="{{{region}}}"
TV Translate Episodes = type=http-response, pattern=^https?:\/\/uts-api\.itunes\.apple\.com\/uts\/v3\/shows\/[^\/]+\/episodes(\?|$), requires-body=1, max-size=2097152, timeout=20, script-path=https://raw.githubusercontent.com/kuroidark/surge/refs/heads/main/script/episodes-translate.js, argument=region="{{{region}}}"
TV Translate Movie Detail = type=http-response, pattern=^https?:\/\/uts-api\.itunes\.apple\.com\/uts\/v3\/movies\/[^\/]+(\?|$), requires-body=1, max-size=2097152, timeout=20, script-path=https://raw.githubusercontent.com/kuroidark/surge/refs/heads/main/script/movie-detail-translate.js, argument=region="{{{region}}}"

[MITM]
hostname = %APPEND% uts-api.itunes.apple.com
