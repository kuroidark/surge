#!name = Apple TV Debug 观察（仅响应侧，不冲突）
#!desc = 只记录 uts-api 响应的状态码 + 非200时的错误正文，不含任何 http-request 脚本，不会跟语言切换模块的请求脚本冲突。跟"Apple TV 内容语言切换"模块一起装。
#!category = Custom

[Script]
TV Debug Response = type=http-response, pattern=^https?:\/\/uts-api\.itunes\.apple\.com\/, requires-body=1, max-size=10485760, script-path=https://raw.githubusercontent.com/kuroidark/surge/refs/heads/main/script/debug-observe-response.js

[MITM]
hostname = %APPEND% uts-api.itunes.apple.com
