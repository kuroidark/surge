#!name= 流媒体 & AI 服务解锁检测
#!desc= 检测 Netflix / ChatGPT / Claude / Gemini / Disney+ / YouTube Premium / Spotify / TikTok 在当前网络下的可用性,通过 Surge 面板手动刷新查看结果
#!category=面板
#!author=you

[Script]
media-unlock-check = type=generic, timeout=25, script-path=https://raw.githubusercontent.com/kuroidark/surge/refs/heads/main/script/media-unlock-check.js

[Panel]
流媒体&AI解锁检测 = script-name=media-unlock-check, update-interval=0
